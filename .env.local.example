# Local Development Environment Variables
# Copy this file to .env.local for local development

# MongoDB Connection (use local MongoDB for development)
MONGODB_URI=mongodb://localhost:27017/deepsea-finvest-dev

# JWT Secret (use a different secret for development)
JWT_SECRET=dev-secret-key-change-in-production

# Admin Credentials
ADMIN_USERNAME=admin
# Generate with: node -e "console.log(require('bcryptjs').hashSync('admin123', 10))"
ADMIN_PASSWORD_HASH=$2a$10$YourHashedPasswordHere

# WhatsApp Number
WHATSAPP_NUMBER=919136242706

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
